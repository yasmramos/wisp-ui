{
  "name": "wisp-ui",
  "version": "1.0.0",
  "description": "Wisp — Light as a breath, built with TailwindCSS. Just copy, paste, and let it flow into your project.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:css": "tailwindcss -i ./src/styles/wisp.css -o ./dist/wisp.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/wisp.css -o ./dist/wisp.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "tailwindcss",
    "components",
    "ui",
    "wisp",
    "copy-paste"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2"
  }
}
