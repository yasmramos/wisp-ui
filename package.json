{
  "name": "wisp-ui",
  "version": "1.0.0",
  "description": "Wisp — Light as a breath, built with TailwindCSS. Just copy, paste, and let it flow into your project.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:css": "tailwindcss -i ./src/styles/wisp.css -o ./dist/wisp.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/wisp.css -o ./dist/wisp.css --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "tailwindcss",
    "components",
    "ui",
    "wisp",
    "copy-paste"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
